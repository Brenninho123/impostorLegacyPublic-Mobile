<?xml version="1.0" encoding="utf-8"?>
<project>
	<app title="VS IMPOSTOR LEGACY" file="ImpostorLegacy" packageName="com.motorfrog.impostor" package="com.motorfrog.impostor" main="Main" version="0.2.7" company="MotorFrog" />

	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/>

	<app preloader="flixel.system.FlxPreloader" />

	<set name="SWF_VERSION" value="11.8" />

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" allow-high-dpi="true" />

	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>
	<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<define name="MODS_ALLOWED" if="mobile" />
	<define name="VIDEOS_ALLOWED" if="desktop" />
	<define name="DISCORD_ALLOWED" if="desktop" />

	<classpath name="source" />

	<setenv name="HAXEPATH" value="./"/>

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32bits" />
	<set name="BUILD_DIR" value="${BUILD_DIR}-tracy" if="FEATURE_DEBUG_TRACY"/>

	<assets path="LEGACY.md" rename="CHANGELOG.md"/>

	<section unless="ASSET_REDIRECT">
		<assets path="content/securitydlc" embed="false" if="MODS_ALLOWED DLC"/>
		<assets path="assets/embeds" rename="assets" embed="true"/>
		<assets path="assets/legacy" rename="assets"/>
	</section>

	<section if="desktop">
		<assets path="projFiles/alsoft.ini" rename="alsoft.ini" type="text" if="windows"/>
		<assets path="projFiles/alsoft.ini" rename="alsoft.conf" type="text" unless="windows"/>
	</section>

	<section if="android">
		<permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
		<permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
		<permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
		<permission android:name="android.permission.INTERNET" />
		<permission android:name="android.permission.ACCESS_NETWORK_STATE" />
		<permission android:name="android.permission.VIBRATE" />
		<permission android:name="android.permission.WAKE_LOCK" />
		<activity android:exported="true" />
	</section>

	<haxelib name="openfl"/>
	<haxelib name="flixel"/>
	<haxelib name="flixel-addons"/>
	<haxelib name="flixel-ui" version="2.6.4"/>
	<haxelib name="hscript-iris"/>
	<haxelib name="flixel-animate"/>
	<haxelib name="moonchart"/>
	<haxelib name="haxeui-core" />
	<haxelib name="haxeui-flixel" />
	<haxelib name="funkin.vis"/>
	<haxelib name="grig.audio"/>
	<haxelib name="json2object"/>
	<haxelib name="json5hx"/>
	<haxelib name="hxdiscord_rpc" if="DISCORD_ALLOWED" version="1.2.4"/>
	<haxelib name="hxvlc" if="VIDEOS_ALLOWED"/>

	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxSprite())', 'flixel.FlxSprite')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxBasic())', 'flixel.FlxBasic')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxCamera())', 'flixel.FlxCamera')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxText())', 'flixel.text.FlxText')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxGraphic())', 'flixel.graphics.FlxGraphic')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxDrawBaseItem())', 'flixel.graphics.tile.FlxDrawBaseItem')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxDrawItem())', 'flixel.graphics.tile.FlxDrawQuadsItem')" />
	<haxeflag name="--macro" value="addMetadata('@:build(funkin.backend.macro.FlxMacro.buildFlxDrawItem())', 'flixel.graphics.tile.FlxDrawTrianglesItem')" />

	<haxeflag name="--macro" value="include('funkin')" />
	<haxeflag name="--macro" value="include('flixel', true, ['flixel.addons.nape.*','flixel.addons.editors.*','flixel.addons.tile.FlxRayCastTilemap','flixel.system.macros'])" />

	<haxeflag name="-dce no" />

	<haxedef name="analyzer-optimize" unless='debug'/>

	<haxedef name="haxeui_dont_impose_base_class"/>
	<haxedef name="haxeui_focus_out_on_click"/>

	<define name="hscriptPos"/>

	<section if="FEATURE_DEBUG_TRACY">
		<haxedef name="HXCPP_TELEMETRY"/>
		<haxedef name="HXCPP_TRACY"/>
		<haxedef name="HXCPP_TRACY_MEMORY"/>
		<haxedef name="HXCPP_TRACY_ON_DEMAND"/>
		<haxedef name="absolute-paths"/>
	</section>

	<haxedef name="CRASH_HANDLER"/>
	<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER"/>
	<haxedef name="HXCPP_STACK_LINE" if="CRASH_HANDLER"/>
	<haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER"/>
	<haxedef name="openfl-enable-handle-error" if="CRASH_HANDLER"/>

	<haxedef name="FLX_NO_HEALTH" />
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG" unless="debug" />
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<haxedef name="message.reporting" value="pretty" />
	<haxedef name="no-deprecation-warnings"/>

	<icon path="projFiles/icon/icon16.png" size='16'/>
	<icon path="projFiles/icon/icon32.png" size='32'/>
	<icon path="projFiles/icon/icon64.png" size='64'/>
	<icon path="projFiles/icon/iconOG.png" />
</project>